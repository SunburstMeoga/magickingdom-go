# 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 配置文件路径
CONFIG_PATH=configs/config.yaml

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=magickingdom

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

